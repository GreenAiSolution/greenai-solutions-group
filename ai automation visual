<script>
function roundRect(ctx,x,y,w,h,r){
  ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);
  ctx.quadraticCurveTo(x+w,y,x+w,y+r);ctx.lineTo(x+w,y+h-r);
  ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);
  ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);
  ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();
}
function base(ctx,W,H){
  const g=ctx.createLinearGradient(0,0,W,H);
  g.addColorStop(0,'#061a0a');g.addColorStop(1,'#0d2e14');
  ctx.fillStyle=g;ctx.fillRect(0,0,W,H);
  ctx.strokeStyle='rgba(0,230,118,0.04)';ctx.lineWidth=0.5;
  const s=Math.round(W/6);
  for(let x=0;x<=W;x+=s){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
  for(let y=0;y<=H;y+=s){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
  const r=ctx.createRadialGradient(W*.5,H*.4,0,W*.5,H*.4,W*.6);
  r.addColorStop(0,'rgba(0,230,118,0.09)');r.addColorStop(1,'transparent');
  ctx.fillStyle=r;ctx.fillRect(0,0,W,H);
}
function frame(ctx,W,H){
  const m=10,g=ctx.createLinearGradient(0,0,W,H);
  g.addColorStop(0,'#00e676');g.addColorStop(.5,'rgba(0,230,118,0.2)');g.addColorStop(1,'#00e676');
  ctx.strokeStyle=g;ctx.lineWidth=1.5;
  roundRect(ctx,m,m,W-m*2,H-m*2,10);ctx.stroke();
  const b=W*0.055,o=m+4;ctx.strokeStyle='#00e676';ctx.lineWidth=2;
  [[o,o,1,1],[W-o,o,-1,1],[o,H-o,1,-1],[W-o,H-o,-1,-1]].forEach(([cx,cy,sx,sy])=>{
    ctx.beginPath();ctx.moveTo(cx+sx*b,cy);ctx.lineTo(cx,cy);ctx.lineTo(cx,cy+sy*b);ctx.stroke();
  });
}

const CARDS=[
  {name:'📅 Smart Scheduling',stat:'30 posts/mo automated',
   fn(ctx,W,H){
    base(ctx,W,H);
    const cols=7,rows=4,cw=(W-60)/cols,ch=(H-90)/rows,sx=30,sy=26;
    ['S','M','T','W','T','F','S'].forEach((d,i)=>{
      ctx.font=`700 ${Math.round(W*.052)}px Inter`;ctx.fillStyle='rgba(0,230,118,0.5)';
      ctx.textAlign='center';ctx.fillText(d,sx+i*cw+cw/2,sy+12);
    });
    const sched=[1,2,4,5,8,9,11,12,15,16,18,19,22,23];
    for(let r=0;r<rows;r++) for(let c=0;c<cols;c++){
      const i=r*cols+c,x=sx+c*cw,y=sy+18+r*ch,hit=sched.includes(i);
      ctx.fillStyle=hit?'rgba(0,230,118,0.16)':'rgba(0,230,118,0.03)';
      roundRect(ctx,x+3,y+3,cw-6,ch-6,5);ctx.fill();
      if(hit){
        ctx.fillStyle='#00e676';ctx.shadowColor='#00e676';ctx.shadowBlur=10;
        ctx.beginPath();ctx.arc(x+cw/2,y+ch/2,5,0,Math.PI*2);ctx.fill();ctx.shadowBlur=0;
      }
      ctx.font=`500 ${Math.round(W*.044)}px Inter`;
      ctx.fillStyle=hit?'rgba(0,230,118,0.7)':'rgba(0,230,118,0.18)';
      ctx.textAlign='center';ctx.fillText(i+1,x+cw/2,y+ch-7);
    }
    ctx.textAlign='left';frame(ctx,W,H);
  }},
  {name:'🔍 Hashtag Intelligence',stat:'Updated daily by AI',
   fn(ctx,W,H){
    base(ctx,W,H);
    const tags=[['#detailing',1.4,'#00e676',.85,.22],['#fyp',1.1,'rgba(0,230,118,.7)',.55,.18],
      ['#gilbert',.9,'rgba(0,230,118,.5)',.3,.42],['#ceramic',1.3,'#00e676',.7,.36],
      ['#cardetail',.85,'rgba(0,230,118,.6)',.12,.58],['#autodetail',1.0,'rgba(0,230,118,.8)',.48,.55],
      ['#satisfying',1.2,'#00ff88',.75,.62],['#foryou',.8,'rgba(0,230,118,.45)',.28,.72],
      ['#trending',.95,'rgba(0,230,118,.65)',.58,.78],['#detail',1.1,'rgba(0,230,118,.75)',.1,.84]];
    tags.forEach(([t,s,c,rx,ry])=>{
      ctx.font=`700 ${Math.round(W*.065*s)}px Inter`;ctx.fillStyle=c;
      ctx.textAlign='left';ctx.fillText(t,W*rx,H*ry);
    });
    ctx.textAlign='left';frame(ctx,W,H);
  }},
  {name:'👁 Competitor Watch',stat:'10+ competitors tracked',
   fn(ctx,W,H){
    base(ctx,W,H);
    const cols=3,rows=2,cw=(W-60)/cols,ch=(H-60)/rows;
    for(let r=0;r<rows;r++) for(let c=0;c<cols;c++){
      const x=20+c*cw,y=20+r*ch;
      ctx.fillStyle='rgba(0,230,118,0.05)';roundRect(ctx,x+4,y+4,cw-8,ch-8,8);ctx.fill();
      ctx.strokeStyle='rgba(0,230,118,0.14)';ctx.lineWidth=1;roundRect(ctx,x+4,y+4,cw-8,ch-8,8);ctx.stroke();
      ctx.fillStyle='rgba(0,230,118,0.18)';ctx.beginPath();ctx.arc(x+cw/2,y+ch*.32,13,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='#00e676';ctx.font=`700 ${Math.round(W*.052)}px Inter`;ctx.textAlign='center';
      ctx.fillText(['C1','C2','C3','C4','C5','C6'][r*cols+c],x+cw/2,y+ch*.32+5);
      const bw=(cw-22)*(.35+Math.sin(r*3+c)*.3+.2);
      ctx.fillStyle='rgba(0,230,118,0.12)';roundRect(ctx,x+11,y+ch*.68,cw-22,5,3);ctx.fill();
      ctx.fillStyle='#00e676';roundRect(ctx,x+11,y+ch*.68,bw,5,3);ctx.fill();
    }
    ctx.strokeStyle='rgba(0,230,118,0.25)';ctx.lineWidth=1.5;ctx.setLineDash([5,5]);
    ctx.beginPath();ctx.moveTo(0,H*.47);ctx.lineTo(W,H*.47);ctx.stroke();ctx.setLineDash([]);
    ctx.textAlign='left';frame(ctx,W,H);
  }},
  {name:'💬 Auto Engagement',stat:'Instant AI replies',
   fn(ctx,W,H){
    base(ctx,W,H);
    const msgs=[
      ['Love your work! How much?',false,.1],
      ['AI: Full details from $199. Book at link in bio 🚗',true,.26],
      ['Do you do ceramic coating?',false,.48],
      ['AI: Ceramic from $399. DM us to schedule! ✨',true,.63],
      ['Available this week?',false,.80],
    ];
    msgs.forEach(([t,ai,fy])=>{
      const bw=W*.72,x=ai?W-bw-14:14,y=H*fy;
      ctx.fillStyle=ai?'rgba(0,230,118,0.13)':'rgba(255,255,255,0.04)';
      roundRect(ctx,x,y,bw,H*.11,9);ctx.fill();
      ctx.strokeStyle=ai?'rgba(0,230,118,0.28)':'rgba(255,255,255,0.07)';ctx.lineWidth=1;
      roundRect(ctx,x,y,bw,H*.11,9);ctx.stroke();
      ctx.font=`${ai?600:400} ${Math.round(W*.048)}px Inter`;
      ctx.fillStyle=ai?'#00e676':'rgba(240,247,241,0.65)';
      ctx.textAlign=ai?'right':'left';
      const txt=t.length>38?t.slice(0,38)+'…':t;
      ctx.fillText(txt,ai?x+bw-12:x+12,y+H*.067);
      if(ai){ctx.font=`600 ${Math.round(W*.038)}px Inter`;ctx.fillStyle='rgba(0,230,118,0.45)';ctx.fillText('🤖 · 0s',x+bw-12,y+H*.1);}
    });
    ctx.textAlign='left';frame(ctx,W,H);
  }},
  {name:'📈 Ad Campaign AI',stat:'4.8x average ROAS',
   fn(ctx,W,H){
    base(ctx,W,H);
    const pts=[.88,.76,.8,.63,.68,.52,.43,.36,.27,.19,.14,.09];
    const pw=(W-60)/(pts.length-1),sx=30,sy=22,sh=H-76;
    ctx.beginPath();ctx.moveTo(sx,sy+sh);
    pts.forEach((p,i)=>ctx.lineTo(sx+i*pw,sy+p*sh));
    ctx.lineTo(sx+(pts.length-1)*pw,sy+sh);ctx.closePath();
    const fg=ctx.createLinearGradient(0,sy,0,sy+sh);
    fg.addColorStop(0,'rgba(0,230,118,0.22)');fg.addColorStop(1,'rgba(0,230,118,0)');
    ctx.fillStyle=fg;ctx.fill();
    ctx.beginPath();pts.forEach((p,i)=>i===0?ctx.moveTo(sx,sy+p*sh):ctx.lineTo(sx+i*pw,sy+p*sh));
    ctx.strokeStyle='#00e676';ctx.lineWidth=2.5;ctx.stroke();
    pts.forEach((p,i)=>{ctx.beginPath();ctx.arc(sx+i*pw,sy+p*sh,3.5,0,Math.PI*2);ctx.fillStyle='#00e676';ctx.fill();});
    ctx.fillStyle='rgba(0,230,118,0.12)';roundRect(ctx,W-96,26,80,38,8);ctx.fill();
    ctx.fillStyle='#00e676';ctx.font=`700 ${Math.round(W*.09)}px Orbitron,monospace`;
    ctx.textAlign='center';ctx.fillText('4.8x',W-56,52);
    ctx.font=`600 ${Math.round(W*.045)}px Inter`;ctx.fillStyle='rgba(0,230,118,0.55)';ctx.fillText('ROAS',W-56,65);
    ctx.textAlign='left';frame(ctx,W,H);
  }},
  {name:'📊 Analytics & Reporting',stat:'Weekly AI reports',
   fn(ctx,W,H){
    base(ctx,W,H);
    const bars=[{l:'IG',v:.82,c:'#00e676'},{l:'TK',v:.95,c:'#00ff88'},{l:'FB',v:.6,c:'#00c853'},{l:'YT',v:.72,c:'#00a844'},{l:'LI',v:.5,c:'#009e3d'}];
    const bw=Math.round((W-80)/(bars.length*1.6)),gap=Math.round(bw*.6);
    const tot=bars.length*(bw+gap)-gap,sx2=(W-tot)/2,maxH=H*.52,baseY=H*.74;
    bars.forEach((b,i)=>{
      const x=sx2+i*(bw+gap),bh=b.v*maxH;
      ctx.fillStyle='rgba(0,230,118,0.05)';roundRect(ctx,x,baseY-maxH,bw,maxH,5);ctx.fill();
      const bg=ctx.createLinearGradient(0,baseY-bh,0,baseY);
      bg.addColorStop(0,b.c);bg.addColorStop(1,b.c+'33');
      ctx.fillStyle=bg;roundRect(ctx,x,baseY-bh,bw,bh,5);ctx.fill();
      ctx.fillStyle='#f0f7f1';ctx.font=`700 ${Math.round(W*.052)}px Inter`;ctx.textAlign='center';
      ctx.fillText(b.l,x+bw/2,baseY+16);
      ctx.fillStyle='#00e676';ctx.font=`600 ${Math.round(W*.044)}px Orbitron,monospace`;
      ctx.fillText(Math.round(b.v*100)+'%',x+bw/2,baseY-bh-8);
    });
    // Gold trend line
    const lp=[.3,.34,.28,.2,.14,.1,.07,.05];const lw2=(W-60)/(lp.length-1);
    ctx.beginPath();lp.forEach((p,i)=>i===0?ctx.moveTo(30+i*lw2,H*.18+p*H*.28):ctx.lineTo(30+i*lw2,H*.18+p*H*.28));
    ctx.strokeStyle='#D4AF37';ctx.lineWidth=2;ctx.stroke();
    ctx.textAlign='left';frame(ctx,W,H);
  }},
];

const grid=document.getElementById('featureGrid');
CARDS.forEach(card=>{
  const wrap=document.createElement('div');wrap.className='feature-card';
  const canvas=document.createElement('canvas');canvas.width=480;canvas.height=360;
  card.fn(canvas.getContext('2d'),480,360);
  const label=document.createElement('div');label.className='feature-card-label';
  label.innerHTML=`<span class="fcl-name">${card.name}</span><span class="fcl-stat">${card.stat}</span>`;
  wrap.appendChild(canvas);wrap.appendChild(label);grid.appendChild(wrap);
});
</script>
