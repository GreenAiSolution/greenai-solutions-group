    ctx.shadowBlur = 0;

    // Glow end cap
    const endGrd = ctx.createRadialGradient(barX + barW, barY + bH/2, 0, barX + barW, barY + bH/2, 18);
    endGrd.addColorStop(0, task.color + '88');
    endGrd.addColorStop(1, 'transparent');
    ctx.fillStyle = endGrd;
    ctx.fillRect(barX + barW - 18, barY - 4, 36, bH + 8);

    // Label (left side)
    ctx.font = `500 ${Math.round(W*0.028)}px Inter`;
    ctx.fillStyle = 'rgba(240,247,241,0.75)';
    ctx.textAlign = 'right';
    ctx.fillText(task.label, barX - 12, barY + bH * 0.65);

    // Hours (right side)
    ctx.font = `700 ${Math.round(W*0.032)}px Orbitron, monospace`;
    ctx.fillStyle = task.color;
    ctx.textAlign = 'left';
    ctx.fillText(task.hours + ' hr', barX + barAreaW + 10, barY + bH * 0.68);
  });

  ctx.textAlign = 'left';

  // Total line
  const totalY = topPad + tasks.length * rowH - rowH * 0.06;
  ctx.strokeStyle = 'rgba(0,230,118,0.2)';
  ctx.lineWidth = 1;
  ctx.setLineDash([4,4]);
  ctx.beginPath();
  ctx.moveTo(leftPad, totalY);
  ctx.lineTo(W - rightPad - W*0.04, totalY);
  ctx.stroke();
  ctx.setLineDash([]);

  // Total label
  ctx.font = `800 ${Math.round(W*0.038)}px Orbitron, monospace`;
  ctx.fillStyle = '#00e676';
  ctx.textAlign = 'right';
  ctx.shadowColor = 'rgba(0,230,118,0.6)';
  ctx.shadowBlur = 14;
  ctx.fillText('= 22 hrs total', W - rightPad - W*0.04, totalY - 8);
  ctx.shadowBlur = 0;
  ctx.textAlign = 'left';

  drawBorderFrame(ctx, W, H);
  drawCornerBrackets(ctx, W, H);
})();

