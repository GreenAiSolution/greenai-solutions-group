  margin-bottom: 0.6rem; font-size: 0.82rem;
}
.compare-item.greenai { color: #a0c8a8; }
.compare-item.manual { color: #3a4a3f; }
.ci-icon { font-size: 0.9rem; flex-shrink: 0; margin-top: 1px; }

/* ============================================
   PLATFORMS — SECTION 5
   ============================================ */
.platform-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}
.platform-card {
  background: rgba(13,24,16,0.7);
  border: 1px solid rgba(0,230,118,0.12);
  border-radius: 16px;
  padding: 1.5rem;
  transition: transform 0.3s ease, border-color 0.3s ease;
}
.platform-card:hover {
  transform: translateY(-4px);
  border-color: rgba(0,230,118,0.3);
}
.platform-icon { font-size: 2rem; margin-bottom: 0.75rem; display: block; }
.platform-name {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1rem; font-weight: 700;
  color: #f0f7f1; margin-bottom: 0.75rem;
}
.platform-features { list-style: none; }
.platform-features li {
  font-size: 0.78rem; color: #7a9e82;
  padding: 4px 0;
  border-bottom: 1px solid rgba(0,230,118,0.05);
  display: flex; align-items: center; gap: 8px;
}
.platform-features li:last-child { border: none; }
.pf-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: #00e676;
  flex-shrink: 0;
}

/* ============================================
   STATS ROW — SECTION 6
   ============================================ */
.stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 2rem; }
.stat-card {
  background: rgba(13,24,16,0.7);
  border: 1px solid rgba(0,230,118,0.12);
  border-radius: 14px;
  padding: 1.5rem 1.25rem;
  text-align: center;
}
.stat-num { font-family: 'Orbitron', monospace; font-size: 1.6rem; font-weight: 700; color: #00e676; }
.stat-num.gold { color: #D4AF37; }
.stat-label { font-size: 0.72rem; color: #5a8a62; margin-top: 6px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; }

@media (max-width: 900px) {
  .automation-grid { grid-template-columns: repeat(2, 1fr); }
  .platform-grid { grid-template-columns: repeat(2, 1fr); }
  .stats-row { grid-template-columns: repeat(2, 1fr); }
  .timeline-nodes { grid-template-columns: repeat(2, 1fr); }
  .timeline-line { display: none; }
}
@media (max-width: 600px) {
  .automation-grid { grid-template-columns: 1fr; }
  .compare-grid { grid-template-columns: 1fr; }
  .platform-grid { grid-template-columns: 1fr; }
  .stats-row { grid-template-columns: repeat(2, 1fr); }
  .timeline-nodes { grid-template-columns: 1fr; }
}
</style>
