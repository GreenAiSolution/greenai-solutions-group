<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GreenAI — AI Automation Showcase</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@500;600;700;800&family=Orbitron:wght@700;900&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', sans-serif;
  background: #040b06;
  color: #f0f7f1;
  -webkit-font-smoothing: antialiased;
}

/* ---- TOP BAR ---- */
.topbar {
  position: fixed; top: 0; left: 0; right: 0;
  background: rgba(4,11,6,0.95);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(0,230,118,0.15);
  padding: 14px 32px;
  display: flex; align-items: center; justify-content: space-between;
  z-index: 100;
}
.topbar-logo { font-family: 'Orbitron', monospace; font-size: 1rem; font-weight: 900; }
.topbar-logo span:first-child { color: #00e676; }
.topbar-logo span:last-child { color: #D4AF37; }
.topbar-badge {
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: #D4AF37;
  background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.3);
  padding: 5px 14px; border-radius: 100px;
}

/* ---- PAGE ---- */
.page { max-width: 1200px; margin: 0 auto; padding: 100px 32px 80px; }

/* ---- SECTION HEADER ---- */
.section-header { text-align: center; margin-bottom: 3rem; }
.section-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: #00e676;
  background: rgba(0,230,118,0.08); border: 1px solid rgba(0,230,118,0.2);
  padding: 6px 16px; border-radius: 100px; margin-bottom: 1rem;
}
.section-header h2 {
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800;
  line-height: 1.15; color: #fff; margin-bottom: 0.75rem;
}
.section-header p { font-size: 1rem; color: #5a8a62; max-width: 540px; margin: 0 auto; }

.divider { height: 1px; background: linear-gradient(90deg, transparent, rgba(0,230,118,0.15), transparent); margin: 5rem 0; }

/* ============================================
   AUTOMATION CARDS — SECTION 1
   ============================================ */
.automation-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.auto-card {
  border-radius: 16px;
  overflow: hidden;
  position: relative;
  cursor: default;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.auto-card:hover { transform: translateY(-6px) scale(1.02); box-shadow: 0 20px 60px rgba(0,230,118,0.12); }
.auto-canvas-wrap {
  position: relative;
  overflow: hidden;
}
.auto-canvas-wrap canvas { width: 100%; height: auto; display: block; }
.auto-label {
  padding: 14px 16px;
  background: rgba(13,22,15,0.95);
  border: 1px solid rgba(0,230,118,0.12);
  border-top: none;
  border-radius: 0 0 16px 16px;
}
.auto-label-name { font-family: 'Space Grotesk', sans-serif; font-size: 0.88rem; font-weight: 700; color: #f0f7f1; }
.auto-label-tag { font-size: 0.65rem; font-weight: 700; color: #00e676; letter-spacing: 0.08em; text-transform: uppercase; margin-top: 3px; }

/* ============================================
   TIMELINE — SECTION 2
   ============================================ */
.timeline-wrap {
  position: relative;
  padding: 2rem 0 1rem;
}
.timeline-line {
  position: absolute;
  top: 50px;
  left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, #00e676, rgba(0,230,118,0.3), #00e676);
  z-index: 0;
}
.timeline-nodes {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  position: relative;
  z-index: 1;
}
.timeline-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.timeline-circle {
  width: 56px; height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #00e676, #00c853);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Orbitron', monospace;
  font-size: 1rem; font-weight: 900;
  color: #040b06;
  box-shadow: 0 0 24px rgba(0,230,118,0.5), 0 0 48px rgba(0,230,118,0.2);
  margin-bottom: 1.25rem;
  flex-shrink: 0;
}
.timeline-day {
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: #00e676;
  margin-bottom: 0.4rem;
}
.timeline-card {
  background: rgba(13,24,16,0.7);
  border: 1px solid rgba(0,230,118,0.15);
  border-radius: 12px;
  padding: 1rem 1rem;
  font-size: 0.78rem;
  color: #a0c8a8;
  line-height: 1.55;
}

/* ============================================
   TIME SAVED — SECTION 3
