<script>
/* ============================================
   HELPERS
   ============================================ */
function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `${r},${g},${b}`;
}

function wrapText(ctx, text, x, y, maxW, lineH) {
  const words = text.split(' ');
  let line = '';
  const lines = [];
  for (let w of words) {
    const test = line + w + ' ';
    if (ctx.measureText(test).width > maxW && line !== '') {
      lines.push(line.trim());
      line = w + ' ';
    } else { line = test; }
  }
  if (line.trim()) lines.push(line.trim());
  lines.forEach((l, i) => ctx.fillText(l, x, y + i * lineH));
  return lines.length;
}

function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.lineTo(x+w-r,y);
  ctx.quadraticCurveTo(x+w,y,x+w,y+r);
  ctx.lineTo(x+w,y+h-r);
  ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  ctx.lineTo(x+r,y+h);
  ctx.quadraticCurveTo(x,y+h,x,y+h-r);
  ctx.lineTo(x,y+r);
  ctx.quadraticCurveTo(x,y,x+r,y);
  ctx.closePath();
}

function drawBase(ctx, W, H, glowX, glowY) {
  // Background gradient
  const grd = ctx.createLinearGradient(0, 0, W, H);
  grd.addColorStop(0, '#061a0a');
  grd.addColorStop(1, '#0d2e14');
  ctx.fillStyle = grd;
  ctx.fillRect(0, 0, W, H);

  // Grid overlay
  ctx.strokeStyle = 'rgba(0,230,118,0.04)';
  ctx.lineWidth = 0.5;
  const grid = Math.round(W / 8);
  for (let x = 0; x <= W; x += grid) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); }
  for (let y = 0; y <= H; y += grid) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }

  // Radial glow
  const rad = ctx.createRadialGradient(glowX||W*0.5, glowY||H*0.4, 0, glowX||W*0.5, glowY||H*0.4, W*0.65);
  rad.addColorStop(0, 'rgba(0,230,118,0.12)');
  rad.addColorStop(1, 'transparent');
  ctx.fillStyle = rad;
  ctx.fillRect(0,0,W,H);
}

function drawCornerBrackets(ctx, W, H, accent) {
  const m = 14, bLen = W*0.07, bW = 2;
  ctx.strokeStyle = accent || '#00e676';
  ctx.lineWidth = bW;
  [[m,m],[W-m,m],[m,H-m],[W-m,H-m]].forEach(([cx,cy],idx) => {
    ctx.beginPath();
    ctx.moveTo(cx + (idx%2===0?0:-bLen), cy);
    ctx.lineTo(cx, cy);
    ctx.lineTo(cx, cy + (idx<2?bLen:-bLen));
    ctx.stroke();
  });
}

function drawBorderFrame(ctx, W, H, accent) {
  const grd = ctx.createLinearGradient(0,0,W,H);
  grd.addColorStop(0, accent || '#00e676');
  grd.addColorStop(0.5, 'rgba(0,230,118,0.3)');
  grd.addColorStop(1, accent || '#00e676');
  ctx.strokeStyle = grd;
  ctx.lineWidth = 1.5;
  roundRect(ctx, 14, 14, W-28, H-28, 10);
  ctx.stroke();
}

/* ============================================
   SECTION 1 — AUTOMATION CANVAS CARDS
   ============================================ */
const AUTO_FEATURES = [
  {
    id: 'scheduling',
    icon: '📅',
    headline: 'Smart Scheduling',
    stat: '30 posts/month, zero manual effort',
    name: 'Content Scheduling',
    draw: (ctx, W, H) => {
      drawBase(ctx, W, H, W*0.3, H*0.3);

      // Calendar grid
      const cols = 7, rows = 5;
      const cellW = (W * 0.72) / cols;
      const cellH = (H * 0.48) / rows;
      const startX = W * 0.14;
      const startY = H * 0.22;

      // Calendar header days
      const days = ['S','M','T','W','T','F','S'];
      ctx.font = `600 ${Math.round(W*0.038)}px Inter`;
      ctx.fillStyle = 'rgba(0,230,118,0.5)';
      ctx.textAlign = 'center';
      days.forEach((d, i) => {
        ctx.fillText(d, startX + i*cellW + cellW/2, startY - 10);
      });

      // Calendar cells
      const scheduled = [2,3,5,7,9,10,12,14,16,17,19,21,23,24,26,28];
      let dayNum = 1;
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const cx = startX + c*cellW;
          const cy = startY + r*cellH;
          const isScheduled = scheduled.includes(dayNum);

          // Cell bg
          ctx.fillStyle = isScheduled ? 'rgba(0,230,118,0.15)' : 'rgba(0,230,118,0.03)';
          roundRect(ctx, cx+1, cy+1, cellW-3, cellH-3, 4);
          ctx.fill();

          if (isScheduled) {
            ctx.strokeStyle = 'rgba(0,230,118,0.4)';
            ctx.lineWidth = 1;
            roundRect(ctx, cx+1, cy+1, cellW-3, cellH-3, 4);
            ctx.stroke();
            // Green dot
            ctx.fillStyle = '#00e676';
            ctx.beginPath();
            ctx.arc(cx + cellW/2, cy + cellH*0.65, 3, 0, Math.PI*2);
            ctx.fill();
          }

          // Day number
          ctx.font = `${isScheduled?'700':'400'} ${Math.round(W*0.032)}px Inter`;
          ctx.fillStyle = isScheduled ? '#00e676' : 'rgba(240,247,241,0.25)';
          ctx.fillText(dayNum <= 31 ? dayNum : '', cx + cellW/2, cy + cellH*0.42);
          dayNum++;
        }
      }
      ctx.textAlign = 'left';

      // Icon
      ctx.font = `${Math.round(W*0.09)}px serif`;
      ctx.fillText('📅', W*0.06, H*0.15);

      // Headline
      ctx.font = `800 ${Math.round(W*0.058)}px Space Grotesk, sans-serif`;
      ctx.fillStyle = '#fff';
      ctx.shadowColor = 'rgba(0,230,118,0.5)';
      ctx.shadowBlur = 10;
      ctx.fillText('Smart Scheduling', W*0.06, H*0.78);
      ctx.shadowBlur = 0;

      // Stat
      ctx.font = `500 ${Math.round(W*0.038)}px Inter`;
      ctx.fillStyle = 'rgba(0,230,118,0.8)';
      ctx.fillText('30 posts/month, zero manual effort', W*0.06, H*0.87);

      drawBorderFrame(ctx, W, H);
      drawCornerBrackets(ctx, W, H);
    }
  },
  {
    id: 'hashtag',
    icon: '🔍',
    headline: 'Daily Hashtag AI',
    stat: 'Updated daily by algorithm',
    name: 'Hashtag Intelligence',
    draw: (ctx, W, H) => {
      drawBase(ctx, W, H, W*0.6, H*0.5);

      // Tag cloud
      const tags = [
        { text: '#viral', size: 0.072, x: 0.12, y: 0.28, alpha: 1.0 },
        { text: '#fyp', size: 0.058, x: 0.42, y: 0.22, alpha: 0.9 },
        { text: '#trending', size: 0.065, x: 0.62, y: 0.32, alpha: 1.0 },
        { text: '#marketing', size: 0.042, x: 0.1, y: 0.44, alpha: 0.7 },
        { text: '#ai', size: 0.08, x: 0.35, y: 0.42, alpha: 1.0 },
        { text: '#growth', size: 0.048, x: 0.68, y: 0.48, alpha: 0.75 },
        { text: '#content', size: 0.04, x: 0.14, y: 0.58, alpha: 0.6 },
        { text: '#brand', size: 0.05, x: 0.45, y: 0.6, alpha: 0.8 },
        { text: '#business', size: 0.036, x: 0.66, y: 0.62, alpha: 0.55 },
