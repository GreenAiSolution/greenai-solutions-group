}
.time-canvas-wrap canvas { width: 100%; height: auto; display: block; }

/* ============================================
   COMPARISON — SECTION 4
   ============================================ */
.compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.compare-col { border-radius: 16px; padding: 1.75rem; }
.compare-col.greenai { background: rgba(0,230,118,0.06); border: 1px solid rgba(0,230,118,0.25); }
.compare-col.manual { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); }
.compare-col h3 { font-family: 'Space Grotesk', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 1rem; }
.compare-col.greenai h3 { color: #00e676; }
